# Bootstrap a ma runtime with entities.
#
# Run once before starting the daemon:
#
#   ma --gen-root-cid bootstrap.example.yaml
#
# The command prints the `root_cid`.  Set it as `root_cid` in config.
#
# If `acl:` is set here, it is published to IPFS and used as the root
# transport-gate ACL at startup (unless `--acl-file` overrides it).
#
# Prerequisites:
#   - IPFS Desktop (Kubo) must be running on localhost:5001
#   - EntityNode(s) already published to IPFS:
#       ipfs dag put --store-codec dag-cbor entity.json
#     Use the resulting CID as the entity value below.

runtime:
  # Root transport-gate ACL.
  # Published to IPFS at bootstrap; loaded at startup when no --acl-file is given.
  # Controls who may use the RPC, inbox, and IPFS services.
  # An absent acl: means the daemon falls back to --acl-file (or open access).
  owners:
    - did:ma:k51qzi5uqu5dlgh2drt9od7f7fmfe1u6rf5j2s2acfp9olltfx51oqhnl048xm
  acls:
    open:
      "*": ["*"]
  acl:
    +/owners: ["*"]
    "*":
      - ipfs
      - rpc


  # Kind definitions.
  # Flat map: full protocol ID string → kind descriptor (bootstrap input only).
  # The `protocol` field is omitted — the map key IS the protocol ID.
  # When published to IPFS, the runtime converts this to a nested tree so that
  # IPLD path traversal works:
  #   ipfs dag get .../kinds/ma/python/actor/0.0.1
  kinds:
    # Generic "bring-your-own-compiled-actor" kind — has NO shared `cid`.
    # Every entity of this kind supplies its own compiled Wasm bytes via
    # `EntityNode.behaviour` instead (see ma-runtime-v1.md §11.2/§14.1).
    /ma/python/actor/0.0.1:
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_reply
        - ma_send
        - ma_set_state

    # ── Standard library kinds ────────────────────────────────────────────────
    # Root orchestrator — the only kind allowed to call ma_create_entity.
    /ma/python/root/0.0.1:
      cid:
        "/": bafybeige533l3uc6fc3e7ykoipn6knh3w5tafo7245z7sep7jnex6rnavm
      type: extism
      attributes:
        wasi: true
      api:
        - on_message
      host_functions:
        - ma_reply
        - ma_set_state
        - ma_send
        - ma_create_entity
        - ma_delete_entity
      allow:
        - create *

    # Bijective (two-way) key↔value map.
    # Reads are open to all; writes restricted to parent.
    /ma/python/register/0.0.1:
      cid:
        "/": bafybeiaen4tq325bvkc2jkb7b3ckzfylpc4gx5n6dohrzvtr5pm5jqx4su
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_set_state
        - ma_reply
      allow:
        - "*"

    # Unordered unique-value collection.
    # Reads are open to all; writes restricted to parent.
    /ma/python/set/0.0.1:
      cid:
        "/": bafybeihpyclh2jjykfahseoculz3y3rysohl3g7gqnjz5xsrty6xfobwfi
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_set_state
        - ma_reply
      allow:
        - "*"

    # Atomic integer counter.
    /ma/python/counter/0.0.1:
      cid:
        "/": bafybeigfb4phjvrmwuigpvophw6suktv5njfrzyuz6motzrbf3a2nryacu
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_set_state
        - ma_reply
      allow:
        - "*"


    # Clearing house — two-phase claim/accept placement authority.
    # Tracks who/what is where (containment tree).
    # Build: make -C ../python-ma-actors/ma_runtime_house ipfs
    /ma/python/house/0.0.1:
      cid:
        "/": bafybeifbgwcfjgy6wey5ewm4cu2pshv3oek7vih64zufhizlnv3vieqwzu
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_reply
        - ma_set_state
        - ma_send
        - ma_avatar_id
      allow:
        - "*"

    # Room — social hub entity.
    # Build: make -C ../python-ma-actors/ma_runtime_room ipfs
    /ma/python/room/0.0.1:
      cid:
        "/": bafybeihwot7j6lxqiuzrfboyo4ie5olochmc7mgcu5xutbs2tscwxvfhhu
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_reply
        - ma_set_state
        - ma_send
      allow:
        - "*"

    # Avatar identity registry — pseudonymous IDs + display names.
    # Build: make -C ../python-ma-actors/ma_runtime_avatar ipfs
    /ma/python/avatar/0.0.1:
      cid:
        "/": bafybeiedk3pjxsdfzvbf5kd7lcdot5a5bir6km6zwyavcfpfryis57qkza
      type: extism
      attributes:
        stateful: true
        wasi: true
      api:
        - set_state
        - do_start
        - on_message
      lifecycle:
        - set_state
        - do_start
      host_functions:
        - ma_reply
        - ma_set_state
        - ma_send
        - ma_avatar_id
      allow:
        - "*"

  # Entities — two forms are accepted:
  #
  #   inline:   bootstrap builds and publishes the EntityNode from the descriptor.
  #             `behaviour` is an IPLD link to the Wasm bytes already on IPFS.
  #             `acl` references a named ACL from `acls:` above (empty = deny-all).
  entities:
    # Root orchestrator — the single entry point for entity creation.
    # Build: make -C ../python-ma-actors/ma_runtime_root ipfs
    root:
      kind: /ma/python/root/0.0.1
      acl: open

    # Counter — atomic integer with :get/:set/:inc/:dec/:reset verbs.
    # Build: make -C ../python-ma-actors/counter ipfs
    counter:
      kind: /ma/python/counter/0.0.1
      acl: open

    # Register — bijective key↔value map.
    # Build: make -C ../python-ma-actors/register ipfs
    register:
      kind: /ma/python/register/0.0.1
      acl: open

    # Set — unordered unique-value collection.
    # Build: make -C ../python-ma-actors/set ipfs
    set:
      kind: /ma/python/set/0.0.1
      acl: open

    # Inline form — bootstrap builds and publishes the EntityNode.
    # Generic bring-your-own-compiled-actor kind: no shared cid, so this
    # entity's OWN Wasm binary is supplied via `behaviour` directly.
    # Build: make -C ../python-ma-actors/fortune ipfs
    rms:
      kind: /ma/python/actor/0.0.1
      behaviour:
        /: bafybeiexfrcfv74xxago4ffccvr2nw6rvlbizebcvakn5ojzzfym53pa6i
      acl: open

    # Avatar identity registry — pseudonymous IDs + display names.
    # Must be loaded before house (house calls #avatar:id at enter time).
    avatar:
      kind: /ma/python/avatar/0.0.1
      acl: open

    # Clearing house — placement authority for the runtime world.
    house:
      kind: /ma/python/house/0.0.1
      acl: open

    # The common room.
    # Flow: @avatar:claim 💃  →  @house:enter #room  →  @room:enter <ticket>
    room:
      kind: /ma/python/room/0.0.1
      acl: open
